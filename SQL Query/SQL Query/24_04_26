--aggiungiamo la colonna DettaglioID alla tabella Ordini
ALTER TABLE Ordini
ADD DettaglioID int;

--aggiungiamo i dettagli agli ordini
update Ordini
SET DettaglioID = 4
Where OrdineID=1003;  

--voglio cancellare delle righe
/*devo sempre specificare il WHERE
è sempre meglio scegliere una condizione che sia univoca
ma posso usare delete anche con il null*/
DELETE FROM Ordini
    WHERE DettaglioID=1031;
    go;

/*ho fatto in modo che nelle 2 tabelle Ordini e Dettaglio Ordini i vari ID (dettaglio e ordini) fossero perfettamente 
corrispondenti e apportato i vari UPDATE quando necessario, poi ho cancellato le righe con DettaglioID null*/

UPDATE Ordini 
SET DettaglioID =1006
WHERE OrdineID=1005;

DELETE FROM Ordini
    WHERE DettaglioID is null;
    go;

--aggiungiamo la FOREIGN KEY alla colonna appena aggiunta
/*assegnamo una chiave primaria alla colonna desiderata
usiamo CONSTRAINT, inseriamo FK_nome colonna in comune,(perchè è già stata creata), 
inseriamo FOREIGN KEY e riportiamo la colonna in questione fra parentesi,
aggiungiamo REFERENCES tabella_scelta(colonna_desiderata)*/
--per inserire la foreign key deve esserci corrispondenza perfetta di ID 
alter table Ordini
add constraint FK_Ordini_Dettagli
foreign key (DettaglioID) references DettagliOrdine(DettaglioID);

